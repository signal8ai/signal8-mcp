{
  "name": "@signal8ai/mcp",
  "version": "0.1.0",
  "description": "Signal8 MCP Server - SEC filing intelligence for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "signal8-mcp": "dist/stdio.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start:stdio": "node dist/stdio.js",
    "start:http": "node dist/http-transport.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "express": "^4.18.2"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.10.1",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "signal8",
    "sec",
    "dilution",
    "ai",
    "claude",
    "cursor",
    "model-context-protocol",
    "sec-filings",
    "stock-analysis"
  ],
  "license": "MIT",
  "author": "Signal8 <hello@signal8.ai> (https://signal8.ai)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signal8ai/signal8-mcp.git"
  },
  "homepage": "https://github.com/signal8ai/signal8-mcp#readme",
  "bugs": {
    "url": "https://github.com/signal8ai/signal8-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
